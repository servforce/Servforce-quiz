                k = str(d)[:10]
                try:
                    m2[k] = int(cnt or 0)
                except Exception:
                    m2[k] = 0
            span = max(0, min(max_span_days, (end_day - start_day).days))
            for i in range(span + 1):
                d2 = start_day + timedelta(days=i)
                k2 = d2.isoformat()
                chart_days.append(k2)
                chart_counts.append(int(m2.get(k2, 0)))
        except Exception:
            chart_days = []
            chart_counts = []
            chart_range_start = ""
