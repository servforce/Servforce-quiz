_PHONE_RE = re.compile(r"^1[3-9]\d{9}$")    # 楠岃瘉涓€涓墜鏈哄彿鏄惁绗﹀悎鐗瑰畾瑙勫垯
_FULLWIDTH_DIGITS = str.maketrans("锛愶紤锛掞紦锛旓紩锛栵紬锛橈紮", "0123456789")


# 鎺ユ敹涓€涓瓧绗︿覆绫诲瀷鐨勫弬鏁?value锛岃繑鍥炰竴涓竷灏斿€?True 鎴?False锛岃〃绀鸿鍚嶅瓧鏄惁鏈夋晥
def _is_valid_name(value: str) -> bool:
    v = (value or "").strip()
    return bool(_NAME_RE.fullmatch(v))

# 瀛楃涓茬被鍨嬬殑鍙傛暟 value锛屽苟杩斿洖涓€涓竷灏斿€硷紝琛ㄧず浼犲叆鐨勬墜鏈哄彿鏄惁鏈夋晥
def _is_valid_phone(value: str) -> bool:
    v = (value or "").strip()
    v = v.replace(" ", "").replace("-", "")
    if v.startswith("+86"):
        v = v[3:]
    if v.startswith("86") and len(v) == 13:
        v = v[2:]
    return bool(_PHONE_RE.fullmatch(v))

# 灏嗚緭鍏ョ殑鎵嬫満鍙烽兘鍙樻垚鏍囧噯鐨勮緭鍑?
def _normalize_phone(value: str) -> str:
    v = (value or "").strip()
    v = v.translate(_FULLWIDTH_DIGITS)
    digits = re.sub(r"\D+", "", v)
    if digits.startswith("0086"):
        digits = digits[4:]
    if digits.startswith("86") and len(digits) >= 13:
        cand = digits[2:]
        if _PHONE_RE.fullmatch(cand):
            digits = cand
    if len(digits) > 11:
        tail = digits[-11:]
        if _PHONE_RE.fullmatch(tail):
            digits = tail
    return digits


