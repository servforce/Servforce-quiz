        sort_id = _sort_id_from_exam_key(exam_key)
        if sort_id:
            return redirect(url_for("admin_exam_detail_by_sort_id", exam_id=sort_id))
        return redirect(url_for("admin_exam_detail", exam_key=exam_key))

