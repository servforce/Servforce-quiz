DATABASE_URL=postgresql+psycopg2://postgres:password@127.0.0.1:5432/markdown_quiz
APP_SECRET_KEY=change-me
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin

# LLM (Doubao / Volcengine Ark)
DOUBAO_API_KEY=your_doubao_api_key
# ARK_API_KEY=your_ark_api_key
DOUBAO_MODEL=your_endpoint_id
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=doubao-seed-1-6-250615
LLM_RESPONSE_FORMAT_JSON=0

# LLM retries/timeouts
LLM_RETRY_MAX=3
LLM_RETRY_BACKOFF=1.0
LLM_TIMEOUT_STRUCTURED=300

# Assignment token
# ASSIGNMENT_TOKEN_SECRET=change-me

# Resume details prompt sizing
RESUME_DETAILS_TEXT_MAX_CHARS=80000
RESUME_DETAILS_FOCUS_MAX_CHARS=60000
RESUME_EXPERIENCE_RAW_MAX_CHARS=60000
RESUME_DETAILS_PROMPT_MAX_CHARS=90000


# SMS (Aliyun DYPNS SMS verify)
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_DYPNS_ENDPOINT=dypnsapi.aliyuncs.com
# ALIYUN_DYPNS_REGION_ID=cn-hangzhou
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_SMS_TEMPLATE_CODE=your_sms_template_code
ALIYUN_SMS_TEMPLATE_PARAM={"code":"##code##","min":"5"}
