# PostgreSQL 连接串。
# 默认对应仓库里的 docker-compose 本地开发环境。
DATABASE_URL=postgresql+psycopg2://admin:pasword@127.0.0.1:5433/markdown_quiz

# 应用会话签名密钥。
# 用于 SessionMiddleware 的 cookie 签名，生产环境必须改成随机长字符串。
APP_SECRET_KEY=change-me

# 后台管理员登录账号。
ADMIN_USERNAME=admin

# 后台管理员登录密码。
ADMIN_PASSWORD=password

# Web 监听地址和端口。
APP_HOST=0.0.0.0
PORT=5000

# assignment token 的独立签名密钥。
# 建议与 APP_SECRET_KEY 分开设置；不设置时会回退使用 APP_SECRET_KEY。
ASSIGNMENT_TOKEN_SECRET=change-me

# 直接运行或脚本控制时的 Flask 调试开关。
# `webctl.sh start` 默认会把它们覆盖成 0，避免后台管理进程被 reloader 影响。
APP_DEBUG=1
APP_USE_RELOADER=1

# 可选：只用于 Git 仓库同步的代理地址；会通过 `git -c http.proxy=...` 显式传入，不影响应用进程其它网络请求。
EXAM_REPO_SYNC_PROXY=

# LLM (OpenAI-compatible Responses API)
# 大模型 API Key。
OPENAI_API_KEY=<your_api_key>
# 大模型名称。
OPENAI_MODEL=doubao-seed-2-0-pro-260215
# OpenAI-compatible 接口基础地址。
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 是否要求 Responses 接口返回 JSON 格式。
LLM_RESPONSE_FORMAT_JSON=0

# LLM retries/timeouts
# 大模型请求最大重试次数。
LLM_RETRY_MAX=3
# 大模型重试退避秒数。
LLM_RETRY_BACKOFF=1.0
# 结构化调用超时时间（秒）。
LLM_TIMEOUT_STRUCTURED=300

# 简历解析相关的 prompt 截断长度控制。
RESUME_DETAILS_TEXT_MAX_CHARS=80000
RESUME_DETAILS_FOCUS_MAX_CHARS=60000
RESUME_EXPERIENCE_RAW_MAX_CHARS=60000
RESUME_DETAILS_PROMPT_MAX_CHARS=90000

# SMS Verification (Aliyun PNVS / DYPNS 2017-05-25)
# 最小必填：跑通短信认证只需要下面 4 项。
# 阿里云 AccessKey ID。
ALIYUN_ACCESS_KEY_ID=<your_aliyun_access_key_id>
# 阿里云 AccessKey Secret。
ALIYUN_ACCESS_KEY_SECRET=<your_aliyun_access_key_secret>
# 短信认证签名名称。
ALIYUN_PNVS_SIGN_NAME=速通互联验证服务
# 短信认证模板编号。
ALIYUN_PNVS_TEMPLATE_CODE=100001

# 可选高级配置：只有在默认行为不满足时再填写。
# 号码认证服务 endpoint；默认 dypnsapi.aliyuncs.com。
ALIYUN_PNVS_ENDPOINT=dypnsapi.aliyuncs.com
# 号码认证服务地域；一般可留空。
ALIYUN_PNVS_REGION_ID=
# 支持占位符：##code##（验证码），##min##（有效期分钟数）
ALIYUN_PNVS_TEMPLATE_PARAM={"code":"##code##","min":"##min##"}
# 可选：短信认证方案名。
ALIYUN_PNVS_SCHEME_NAME=
# 可选：国家码。
ALIYUN_PNVS_COUNTRY_CODE=86
# 可选：业务透传 ID。
ALIYUN_PNVS_OUT_ID=
# 可选：验证码有效期（分钟）。
ALIYUN_PNVS_VALID_TIME=5
# 可选：校验策略。
ALIYUN_PNVS_CASE_AUTH_POLICY=
